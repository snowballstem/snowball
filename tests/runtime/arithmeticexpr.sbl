// Test arithmetic expressions (AEs).
externals (stem)
integers (x y)
define stem as (
  $x = 7
  $x /= 4
  $(x == 1) or fail='/= should round to zero (+/+)'

  $y = 7
  $x = y / 4
  $(x == 1) or fail='/ should round to zero (+/+)'

  $(7 / 4 * 4 == 4) or fail='should use integer / (+/+)'

  $x = -7
  $x /= -4
  $(x == 1) or fail='/= should round to zero (-/-)'

  $y = -7
  $x = y / -4
  $(x == 1) or fail='/ should round to zero (-/-)'

  $(-7 / -4 * 4 == 4) or fail='should use integer / (-/-)'

  $x = -7
  $x /= 4
  $(x == -1) or fail='/= should round to zero (-/+)'

  $y = -7
  $x = y / 4
  $(x == -1) or fail='/ should round to zero (-/+)'

  $(-7 / 4 * 4 == -4) or fail='should use integer / (-/+)'

  $x = 7
  $x /= -4
  $(x == -1) or fail='/= should round to zero (+/-)'

  $y = 7
  $x = y / -4
  $(x == -1) or fail='/ should round to zero (+/-)'

  $(7 / -4 * 4 == -4) or fail='should use integer / (+/-)'
)

