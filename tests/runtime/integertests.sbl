// Test integer tests.
externals (stem)
routines (var_local_bug var_local_bug_)
integers (x y var_local_bug_a var_local_bug_b)
define stem as (
  var_local_bug

  $x = len

  $x == 2 or fail='== failed (old style)'
  $(x == 2) or fail='== failed'
  $(2 == x) or fail='== failed (reversed)'

  $x != 3 or fail='!= failed (old style)'
  $(x != 3) or fail='!= failed'
  $(3 != x) or fail='!= failed (reversed)'

  $x >= 2 or fail='>= failed (old style)'
  $(x >= 2) or fail='>= failed'
  $(x >= 1) or fail='>= failed (nonequal)'
  $(2 >= x) or fail='>= failed (reversed)'
  $(3 >= x) or fail='>= failed (nonequal, reversed)'

  $x <= 2 or fail='<= failed (old style)'
  $(x <= 2) or fail='<= failed'
  $(x <= 3) or fail='<= failed (nonequal)'
  $(2 <= x) or fail='<= failed (reversed)'
  $(1 <= x) or fail='<= failed (nonequal, reversed)'

  $x > 1 or fail='> failed (old style)'
  $(x > 1) or fail='> failed'
  $(3 > x) or fail='> failed (nonequal, reversed)'

  $x < 3 or fail='< failed (old style)'
  $(x < 3) or fail='< failed'
  $(1 < x) or fail='< failed (reversed)'
)

// Regression test for bug in fixed in 3.1.1 - the variable localisation
// machinery failed to look at the rhs of integer tests.
define var_local_bug as (
  $var_local_bug_a = 0
  var_local_bug_
  $var_local_bug_a = 1
  var_local_bug_
)

define var_local_bug_ as (
  do (
    $(var_local_bug_a == 1)
    // The bug was that this use before set was not spotted.
    $(7 != var_local_bug_b)
    ['a'] delete
  )
  do (
    $(var_local_bug_a == 0)
    $var_local_bug_b = 7
  )
  $(7 == var_local_bug_b) or fail='var_local_bug_b was incorrectly localised'
)
